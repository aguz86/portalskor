rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - uid: string (required)
    //   - username: string (required)
    //   - email: string (required)
    //   - role: string (required, enum: ['admin', 'user'])
    //   - balance: number (required)
    //
    // Collection: matches
    // Document ID: matchId
    // Fields:
    //   - teamA: string (required)
    //   - teamB: string (required)
    //   - status: string (required, enum: ['open', 'closed'])
    //   - resultA: number (optional)
    //   - resultB: number (optional)
    //   - createdAt: timestamp (optional)
    //
    // Collection: predictions
    // Document ID: predictionId
    // Fields:
    //   - userId: string (required)
    //   - matchId: string (required)
    //   - scoreA: number (required)
    //   - scoreB: number (required)
    //   - status: string (required, enum: ['pending', 'won', 'lost'])
    //   - createdAt: timestamp (optional)
    //
    // Collection: withdrawals
    // Document ID: withdrawalId
    // Fields:
    //   - userId: string (required)
    //   - amount: number (required)
    //   - status: string (required, enum: ['pending', 'approved', 'rejected'])
    //   - createdAt: timestamp (optional)
    //
    // ===============================================================

    // Collection: settings
    // Document ID: config
    // Fields:
    //   - webName: string (required)
    //   - adminEmail: string (required)
    //   - isInstalled: boolean (required)
    //   - installedAt: timestamp (optional)
    //
    // ===============================================================
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      let configPath = /databases/$(database)/documents/settings/config;
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return isAuthenticated() && 
             (
               (exists(userPath) && get(userPath).data.role == 'admin') ||
               (exists(configPath) && request.auth.token.email == get(configPath).data.adminEmail && request.auth.token.email_verified == true) ||
               (request.auth.token.email == "agusse9986@gmail.com" && request.auth.token.email_verified == true)
             );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'username', 'email', 'role', 'balance']) &&
        data.uid is string &&
        data.username is string && data.username.size() >= 3 && data.username.size() <= 20 &&
        data.email is string &&
        data.role in ['admin', 'user'] &&
        data.balance is number && data.balance >= 0;
    }

    function isValidMatch(data) {
      return data.keys().hasAll(['teamA', 'teamB', 'status', 'deadline', 'totalPrize', 'winnerCount']) &&
        data.teamA is string && data.teamA.size() > 0 && data.teamA.size() <= 50 &&
        data.teamB is string && data.teamB.size() > 0 && data.teamB.size() <= 50 &&
        data.status in ['open', 'closed'] &&
        data.deadline is timestamp &&
        data.totalPrize is number && data.totalPrize >= 0 &&
        data.winnerCount is number && data.winnerCount >= 1;
    }

    function isValidPrediction(data) {
      return data.keys().hasAll(['userId', 'matchId', 'scoreA', 'scoreB', 'status']) &&
        data.userId == request.auth.uid &&
        data.matchId is string &&
        data.scoreA is number && data.scoreA >= 0 &&
        data.scoreB is number && data.scoreB >= 0 &&
        data.status == 'pending';
    }

    function isValidWithdrawal(data) {
      return data.keys().hasAll(['userId', 'amount', 'status']) &&
        data.userId == request.auth.uid &&
        data.amount is number && data.amount > 0 &&
        data.status == 'pending';
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && (request.resource.data.role == 'user' || isAdmin());
      allow update: if isAuthenticated() && (isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role && request.resource.data.balance == resource.data.balance));
    }

    match /matches/{matchId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    match /predictions/{predictionId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidPrediction(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /withdrawals/{withdrawalId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidWithdrawal(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /settings/config {
      allow read: if true;
      allow create: if !exists(/databases/$(database)/documents/settings/config);
      allow update: if isAdmin();
    }
  }
}
